# EditorConfig — consistent coding styles across editors
# https://editorconfig.org

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python
[*.py]
indent_size = 4
max_line_length = 100

# YAML (GitHub Actions, Docker Compose)
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# HTML, CSS, JavaScript
[*.{html,css,js}]
indent_size = 4

# TOML
[*.toml]
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false

# Dockerfile
[Dockerfile]
indent_size = 4

# Makefile (requires tabs)
[Makefile]
indent_style = tab
