# .env.example

# LLM Settings
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# Embedding
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMENSION=384

# Reranker
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVAL_TOP_K=20

# Hardware
ENABLE_GPU=auto

# Features
MULTILINGUAL_MODE=false
MAX_FILE_SIZE_MB=50

# API
API_HOST=0.0.0.0
API_PORT=8000
