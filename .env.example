# ─────────────────────────────────────────────────────────────────────────────
# Document AI + RAG Pipeline — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── LLM (Ollama) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Embedding Model ──────────────────────────────────────────────────────
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMENSION=384

# ── Reranker Model ───────────────────────────────────────────────────────
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5

# ── OCR ──────────────────────────────────────────────────────────────────
OCR_LANGUAGE=en
OCR_USE_ANGLE_CLS=true

# ── Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20

# ── Document Upload ──────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── GPU Acceleration ─────────────────────────────────────────────────────
# Options: "auto" (detect at startup), "true" (force GPU), "false" (force CPU)
ENABLE_GPU=auto

# ── Multi-Language Mode ──────────────────────────────────────────────────
# When enabled, auto-detects document language and uses appropriate OCR engine
MULTILINGUAL_MODE=false
MULTILINGUAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MULTILINGUAL_EMBED_DIMENSION=384

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
