# .env.example — Document AI + RAG Pipeline v3.0

# ── LLM Settings ──────────────────────────────────────────────────────────────
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMENSION=384

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20

# ── Hardware ──────────────────────────────────────────────────────────────────
ENABLE_GPU=auto

# ── Features ──────────────────────────────────────────────────────────────────
MULTILINGUAL_MODE=false
MAX_FILE_SIZE_MB=50

# ── Query Caching (v3.0) ─────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_MAX_SIZE=128
CACHE_TTL_SECS=3600

# ── Rate Limiting (v3.0) ─────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── SQLite Sessions (v3.0) ───────────────────────────────────────────────────
SQLITE_DB_NAME=sessions.db

# ── Knowledge Graph (v3.0) ───────────────────────────────────────────────────
KNOWLEDGE_GRAPH_ENABLED=true

# ── WebSocket Collaboration (v3.0) ───────────────────────────────────────────
WS_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
