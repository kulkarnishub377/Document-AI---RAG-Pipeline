# ─────────────────────────────────────────────────────────────────────────────
# Document AI + RAG Pipeline — Environment Settings
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env' and modify as needed.

# ── API Settings
API_HOST=0.0.0.0
API_PORT=8000

# ── Model Settings
# The embedding model to use (downloaded automatically from HuggingFace)
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMENSION=384

# The reranker model to use
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5

# The Ollama model to use for generation (must be pulled via `ollama pull`)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# ── Document Processing
# Maximum file size allowed for upload in MB
MAX_FILE_SIZE_MB=50

# Language code for PaddleOCR (en, ch, hi, etc.)
OCR_LANGUAGE=en
# Whether to run angle classification to fix rotated text before OCR
OCR_USE_ANGLE_CLS=true

# ── Indexing
# How many characters per chunk
CHUNK_SIZE=512
# How many characters overlap between consecutive chunks
CHUNK_OVERLAP=64
# How many chunks to retrieve per query initially
RETRIEVAL_TOP_K=20

# ── System
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
