# ─────────────────────────────────────────────────────────────────────────────
# Document AI + RAG Pipeline v3.1.0 — Environment Configuration
# Copy this file to .env and adjust values as needed
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" (default, fully local) or "openai" (cloud, needs API key)
LLM_PROVIDER=ollama

# ── Ollama Settings ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_VISION_MODEL=llava

# ── OpenAI Settings (only used when LLM_PROVIDER=openai) ────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_BASE_URL=                # Leave empty for default, set for Azure/custom

# ── LLM Timeout ──────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECS=120

# ── Embedding Model ──────────────────────────────────────────────────────────
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMENSION=384

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_K=5

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS Origins (comma-separated) ──────────────────────────────────────────
CORS_ORIGINS=*

# ── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── GPU Acceleration ─────────────────────────────────────────────────────────
# Options: "auto" (detect), "true" (force), "false" (CPU only)
ENABLE_GPU=auto

# ── OCR ──────────────────────────────────────────────────────────────────────
OCR_LANGUAGE=en
OCR_USE_ANGLE_CLS=true

# ── Multi-Language Support ───────────────────────────────────────────────────
MULTILINGUAL_MODE=false

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=20

# ── FAISS Index ──────────────────────────────────────────────────────────────
# Auto-switch to IVF index when vector count exceeds this threshold
IVF_THRESHOLD=50000

# ── Query Caching ────────────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_MAX_SIZE=128
CACHE_TTL_SECS=3600

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── Knowledge Graph ──────────────────────────────────────────────────────────
KNOWLEDGE_GRAPH_ENABLED=true
KG_MAX_ENTITIES_PER_CHUNK=10

# ── WebSocket ────────────────────────────────────────────────────────────────
WS_ENABLED=true

# ── Scheduled Web Crawling (v3.1) ────────────────────────────────────────────
CRAWL_ENABLED=false
CRAWL_INTERVAL_MINS=1440

# ── Query Analytics (v3.1) ───────────────────────────────────────────────────
QUERY_ANALYTICS_ENABLED=true

# ── Document Versioning (v3.1) ───────────────────────────────────────────────
DOC_VERSIONING_ENABLED=true

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
